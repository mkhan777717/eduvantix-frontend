generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                    @id @default(autoincrement())
  email                 String                 @unique
  username              String                 @unique
  password              String
  role                  Role                   @default(USER)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  contestsCreated       Contest[]              @relation("ContestCreator")
  contestParticipations ContestParticipation[]
  liveSessions          LiveSession[]          @relation("SessionHost")
  submissions           Submission[]
  vivaSessions          VivaSession[]
}

model Problem {
  id              Int              @id @default(autoincrement())
  title           String
  slug            String           @unique
  difficulty      Difficulty
  statement       String
  inputFormat     String
  outputFormat    String
  constraints     String
  explanation     String
  timeout         Int              @default(2000)
  memoryLimit     Int              @default(256)
  comparator      String           @default("tokens")
  epsilon         Float            @default(0.000001)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  contestProblems ContestProblem[]
  submissions     Submission[]
  testCases       TestCase[]
}

model TestCase {
  id             Int      @id @default(autoincrement())
  input          String
  expectedOutput String
  isSample       Boolean  @default(false)
  problemId      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Submission {
  id            Int              @id @default(autoincrement())
  userId        Int
  problemId     Int
  language      Language
  code          String
  status        SubmissionStatus @default(PENDING)
  executionTime Int?
  createdAt     DateTime         @default(now())
  problem       Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contest {
  id                    Int                    @id @default(autoincrement())
  title                 String
  description           String?
  startTime             DateTime
  endTime               DateTime
  creatorId             Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  category              String?
  creator               User?                  @relation("ContestCreator", fields: [creatorId], references: [id])
  contestParticipations ContestParticipation[]
  contestProblems       ContestProblem[]
}

model ContestProblem {
  id        Int     @id @default(autoincrement())
  contestId Int
  problemId Int
  points    Int     @default(100)
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([contestId, problemId])
}

model ContestParticipation {
  id        Int      @id @default(autoincrement())
  userId    Int
  contestId Int
  completed Boolean  @default(false)
  score     Int      @default(0)
  timeSpent String?
  createdAt DateTime @default(now())
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
}

model LiveSession {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  thumbnailUrl  String?
  roomName      String    @unique
  hostId        Int
  isLive        Boolean   @default(false)
  scheduledAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  recordingUrl  String?
  recordingSize Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  host          User      @relation("SessionHost", fields: [hostId], references: [id])
  polls         LivePoll[]
}

model VivaQuestion {
  id             Int          @id @default(autoincrement())
  subject        String
  topic          String       @default("")
  questionText   String
  expectedAnswer String
  keywords       String
  difficulty     Difficulty   @default(EASY)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  vivaAnswers    VivaAnswer[]
}

model VivaSession {
  id          Int          @id @default(autoincrement())
  userId      Int
  subject     String
  status      String       @default("STARTED")
  score       Int          @default(0)
  feedback    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  vivaAnswers VivaAnswer[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VivaAnswer {
  id         Int          @id @default(autoincrement())
  sessionId  Int
  questionId Int
  answerText String
  score      Int          @default(0)
  feedback   String?
  createdAt  DateTime     @default(now())
  question   VivaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session    VivaSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
  MENTOR
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Language {
  JAVASCRIPT
  PYTHON
  CPP
  JAVA
}

enum SubmissionStatus {
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  COMPILATION_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  INTERNAL_ERROR
  PENDING
}

// ─── Live Polling ─────────────────────────────────────────────────────────────

model LivePoll {
  id          Int              @id @default(autoincrement())
  sessionId   Int
  question    String
  options     String[]
  correctIdx  Int
  timerSecs   Int              @default(30)
  launchedAt  DateTime         @default(now())
  endedAt     DateTime?
  session     LiveSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers     LivePollAnswer[]
}

model LivePollAnswer {
  id          Int      @id @default(autoincrement())
  pollId      Int
  username    String
  chosenIdx   Int
  timeMs      Int
  isCorrect   Boolean
  points      Int      @default(0)
  answeredAt  DateTime @default(now())
  poll        LivePoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, username])
}
